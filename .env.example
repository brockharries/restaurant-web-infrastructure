# Copy this file to `.env` and fill in real values LOCALLY.
# `.env` is gitignored. Never commit real secrets.

# --- Database ---
DB_NAME=storefront
DB_USER=storefront
DB_PASSWORD=<REDACTED-generate-a-strong-password>
DB_ROOT_PASSWORD=<REDACTED-generate-a-different-strong-password>

# --- Payment processor (PCI-compliant, hosted flow) ---
# The origin only holds API keys for tokenized charges. It NEVER stores or
# transmits raw card numbers. The customer enters card data on the
# processor's hosted fields, not on our origin.
PAYMENT_PUBLISHABLE_KEY=<REDACTED-processor-publishable-key>
PAYMENT_SECRET_KEY=<REDACTED-processor-secret-key>

# --- Public site ---
PUBLIC_HOSTNAME=example.com

# --- Backups (see scripts/backup.example.sh) ---
BACKUP_REMOTE=<REDACTED-offsite-storage-target>   # e.g. s3://bucket or user@host:/path
BACKUP_RETENTION_DAYS=14
